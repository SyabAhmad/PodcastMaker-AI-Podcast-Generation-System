# =============================================================================
# PodcastMaker - Environment Configuration
# =============================================================================
# Copy this file to backend/.env and fill in your values.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=PodcastMaker
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_HOST=0.0.0.0
API_PORT=8000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=podcastmaker
POSTGRES_PASSWORD=change-me
POSTGRES_DB=podcastmaker

# ── Groq (LLM) — get key from console.groq.com ────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── TTS Provider ────────────────────────────────────────────────────────────
# Set TTS_PROVIDER to your preferred: edge | openai | elevenlabs
TTS_PROVIDER=edge

# Edge TTS (free, no API key needed)
EDGE_TTS_ENABLED=1
EDGE_TTS_VOICE=en-US-GuyNeural

# OpenAI TTS (requires API key, ~$0.015/1K chars)
OPENAI_TTS_ENABLED=0
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# ElevenLabs TTS (requires API key, high quality)
ELEVENLABS_TTS_ENABLED=0
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Available Voices ─────────────────────────────────────────────────────────
# Format: provider:voice_id:name (comma-separated)
AVAILABLE_VOICES=edge:en-US-GuyNeural:host,edge:en-US-JennyNeural:guest,edge:en-US-AriaNeural:narrator,edge:en-US-DavisNeural:deep,edge:en-US-SaraNeural:energetic,edge:en-GB-RyanNeural:british

# ── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ──────────────────────────────────────────────────────────────────
AUDIO_STORAGE_PATH=./storage/audio
